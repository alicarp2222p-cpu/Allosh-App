{
  "name": "vag_shop",
  "version": "1.0.0",
  "description": "VAG Shop Management System",
  "main": "main.js",
  "scripts": {
    "start": "node server.js",
    "start-electron": "electron .",
    "dist": "electron-builder --win"
  },
  "build": {
    "appId": "com.vag.shop",
    "productName": "VAG Shop Manager",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "nsis",
      "icon": "public/1000117025.png"
    },
    "files": [
      "**/*",
      "!node_modules/.cache",
      "!dist",
      "!*.log"
    ]
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "multer": "^1.4.5-lts.1",
    "mysql2": "^3.6.0",
    "nodemailer": "^8.0.10"
  },
  "devDependencies": {
    "electron": "^41.5.1",
    "electron-builder": "^24.13.3"
  }
}
